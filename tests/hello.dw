moduleFrom "./MyApp.json"
exportTo "./MyApp.js"
importFrom $MyString as string

when IS LOADED
  locate $MyString center center
  size $MyString full full
  setAttribute $MyString \
    "font" "monospace"
  setAttribute $MyString \
    "fontSize" 32
  setAttribute $MyString \
    "text" "Hello, World!"
  setAttribute $MyString \
    "textAlign" "center"
  show $MyString
end

when IS HOVER $MyString
  setAttribute $MyString \
    "fontSize" 48
end

when NOT HOVER $MyString
  setAttribute $MyString \
    "fontSize" 32
end
